rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // Bloqueo total por defecto
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Clínicas ──────────────────────────────────────────────
    match /clinicas/{clinicId} {
      allow read: if isAuthenticated();

      // Crear clínica nueva (onboarding) — la clínica no existe todavía
      allow create: if isAuthenticated();

      // Actualizar clínica existente — solo si ya existe
      allow update: if isAuthenticated()
                    && exists(/databases/$(database)/documents/clinicas/$(clinicId));

      // Nunca borrar clínicas
      allow delete: if false;

      match /config/{configDoc} {
        allow read:  if isAuthenticated();
        allow write: if isAuthenticated();
      }

      match /pacientes/{pacienteId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated()
                               && request.resource.data.keys().hasAll(['id', 'nombre'])
                               && request.resource.data.nombre is string
                               && request.resource.data.nombre.size() > 0
                               && request.resource.data.nombre.size() <= 120;
        allow delete: if false;
      }
    }

    // ── Registro anti-spam de emails ──────────────────────────
    match /registros/{emailKey} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ── Prospectos — leads que iniciaron onboarding ──────────
    // Se crea al avanzar el paso 1, se marca completado=true al crear la clínica
    match /prospectos/{emailKey} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ── Sentinel: pulso de vida por clínica ───────────────────
    match /smile_health/{clinicId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ── Sentinel: errores de la app ───────────────────────────
    match /smile_errors/{errorId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ── Admin panel ───────────────────────────────────────────
    match /admin/{document=**} {
      allow read, write: if false;
    }
  }
}
